<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="4dp">

    <Space
        android:id="@+id/codeLeadingSpace"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="0.12" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.76"
        android:background="@drawable/bg_chat_bot"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/codeLanguage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="TEXT"
                android:textAllCaps="true"
                android:textColor="#D1D5DB"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/codeCopyHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/code_copy_hint"
                android:textColor="#9CA3AF"
                android:textSize="12sp" />
        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/codeScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#111827"
            android:fillViewport="false"
            android:padding="10dp"
            android:scrollbars="horizontal">

            <TextView
                android:id="@+id/messageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                android:textColor="#F9FAFB"
                android:textIsSelectable="true"
                android:textSize="14sp" />
        </HorizontalScrollView>
    </LinearLayout>

    <Space
        android:id="@+id/codeTrailingSpace"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="0.12" />

</LinearLayout>
