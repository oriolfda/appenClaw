<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="4dp">

    <Space
        android:id="@+id/codeLeadingSpace"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="0.12" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.84"
        android:background="@drawable/bg_code_block"
        android:clipToOutline="true"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="36dp"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/codeLanguage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="TEXT"
                android:textColor="#F5F5F5"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/codeCopyIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/code_copy_hint"
                android:src="@drawable/ic_content_copy"
                android:tint="#D4D4D8" />
        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/codeScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#171717"
            android:fadeScrollbars="false"
            android:fillViewport="false"
            android:paddingStart="18dp"
            android:paddingTop="8dp"
            android:paddingEnd="18dp"
            android:paddingBottom="14dp"
            android:scrollbars="horizontal">

            <TextView
                android:id="@+id/messageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingExtra="4dp"
                android:textColor="#F5F5F5"
                android:textIsSelectable="true"
                android:textSize="14sp" />
        </HorizontalScrollView>
    </LinearLayout>

    <Space
        android:id="@+id/codeTrailingSpace"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="0.04" />


</LinearLayout>
