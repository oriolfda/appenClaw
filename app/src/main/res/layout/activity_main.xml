<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AIGOR app en marxa 🚀"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Endpoint OpenClaw"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/endpointEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://192.168.0.210:8080/openclaw/input"
            android:inputType="textUri"
            android:singleLine="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Hook token"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/tokenEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Bearer token de hooks"
            android:inputType="textPassword"
            android:singleLine="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Missatge (text + URLs)"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/messageEdit"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:gravity="top|start"
            android:hint="Escriu text o enganxa URLs"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="6" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Enviar a OpenClaw" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Estat: llest"
            android:textColor="#333333" />

    </LinearLayout>
</ScrollView>
